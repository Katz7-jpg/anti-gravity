{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Memory Bank Sync Manifest",
    "description": "Schema for Memory Bank synchronization manifest",
    "type": "object",
    "required": [
        "version",
        "lastSync",
        "sourceHash",
        "targets"
    ],
    "properties": {
        "version": {
            "type": "string",
            "description": "Manifest version",
            "default": "1.0"
        },
        "lastSync": {
            "type": "string",
            "format": "date-time",
            "description": "ISO8601 timestamp of last sync"
        },
        "sourceHash": {
            "type": "string",
            "description": "SHA-256 hash of source directory"
        },
        "targets": {
            "type": "object",
            "description": "Target platforms and their sync status",
            "properties": {
                "gemini": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "path": {
                            "type": "string"
                        },
                        "hash": {
                            "type": "string"
                        },
                        "status": {
                            "type": "string",
                            "enum": [
                                "success",
                                "failed",
                                "skipped"
                            ]
                        },
                        "lastSync": {
                            "type": "string",
                            "format": "date-time"
                        },
                        "message": {
                            "type": "string"
                        }
                    }
                },
                "kilocode_cli": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "path": {
                            "type": "string"
                        },
                        "hash": {
                            "type": "string"
                        },
                        "status": {
                            "type": "string",
                            "enum": [
                                "success",
                                "failed",
                                "skipped"
                            ]
                        },
                        "lastSync": {
                            "type": "string",
                            "format": "date-time"
                        },
                        "message": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "filesSynced": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of files that were synced"
        },
        "validationResults": {
            "type": "object",
            "properties": {
                "passed": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "warnings": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "blocked": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    }
}